{
  "name": "lottery-app",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.lottery.app",
    "productName": "抽奖系统",
    "directories": {
      "output": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "assets/**"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
